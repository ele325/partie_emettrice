                "C:/Espressif/frameworks/esp-idf-v5.3.1/components/spi_flash/include",

                // Newlib
                "C:/Espressif/frameworks/esp-idf-v5.3.1/components/newlib/platform_include",

                // Sleep
                "C:/Espressif/frameworks/esp-idf-v5.3.1/components/esp_pm/include",

                // sdkconfig.h — généré après idf.py build
                "${workspaceFolder}/build/config"
            ],

            "defines": [
                "ESP_PLATFORM",
                "IDF_VER=\"v5.3.1\"",
                "CONFIG_IDF_TARGET_ESP32S3=1",
                "CONFIG_IDF_TARGET=\"esp32s3\"",
                "__xtensa__",
                "SOC_CPU_CORES_NUM=2",
                "configNUM_CORES=2"
            ],

            "browse": {
                "path": [
                    "${workspaceFolder}",
                    "C:/Espressif/frameworks/esp-idf-v5.3.1/components"
                ],
                "limitSymbolsToIncludedHeaders": false
            }
        }
    ],
    "version": 4
}